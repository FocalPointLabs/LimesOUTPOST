{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "VisualAgent output contract. Validates the visual_output wrapper returned by run().",
  "type": "object",
  "required": [
    "status",
    "visual_output"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error"
      ]
    },
    "visual_output": {
      "type": "object",
      "required": [
        "scenes",
        "video_metadata"
      ],
      "properties": {
        "scenes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "scene_id",
              "visual_prompt",
              "task_id",
              "video_file_path"
            ],
            "properties": {
              "scene_id": {
                "type": "integer"
              },
              "visual_prompt": {
                "type": "string",
                "minLength": 1
              },
              "task_id": {
                "type": "string"
              },
              "video_file_path": {
                "type": "string"
              }
            }
          }
        },
        "video_metadata": {
          "type": "object",
          "required": [
            "provider"
          ],
          "properties": {
            "provider": {
              "type": "string"
            },
            "mode": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}