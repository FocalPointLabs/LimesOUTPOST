{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "BlogStrategyAgent output contract. Validates the blog_strategy_output returned by run().",
  "type": "object",
  "required": ["status", "chosen_topic", "blog_strategy_output"],
  "properties": {
    "status": { "type": "string" },
    "chosen_topic": { "type": "string", "minLength": 1 },
    "directive_used": { "type": "boolean" },
    "blog_strategy_output": {
      "type": "object",
      "required": ["venture_id", "headline", "primary_keyword", "meta_description", "angle", "hook_sentence", "section_plan", "cta"],
      "properties": {
        "venture_id": { "type": "string" },
        "niche_focus": { "type": "string" },
        "headline": { "type": "string", "minLength": 10 },
        "primary_keyword": { "type": "string", "minLength": 3 },
        "secondary_keywords": { "type": "array", "items": { "type": "string" } },
        "meta_description": { "type": "string", "maxLength": 155 },
        "angle": { "type": "string", "minLength": 1 },
        "hook_sentence": { "type": "string", "minLength": 1 },
        "section_plan": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["heading", "key_point"],
            "properties": {
              "heading": { "type": "string", "minLength": 1 },
              "key_point": { "type": "string", "minLength": 1 }
            }
          }
        },
        "cta": { "type": "string" },
        "estimated_word_count": { "type": "integer", "minimum": 100 },
        "style_config": { "type": "object" }
      }
    }
  }
}
